{
  "name": "smartRetail",
  "version": "0.1.0",
  "private": true,
  "description": "SMART_RETAIL - Smart Retail & Logistics System (Aduana de Control Ciberfísica)",
  "keywords": [
    "smart-retail",
    "iot",
    "hexagonal-architecture",
    "nestjs",
    "react-native"
  ],
  "author": "SMART_RETAIL Team",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:cov": "turbo run test:cov",
    "test:e2e": "jest --config tests/e2e/jest.config.ts",
    "test:e2e:setup": "docker compose -f docker-compose.test.yml up -d",
    "test:e2e:teardown": "docker compose -f docker-compose.test.yml down -v",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "turbo run clean && rimraf node_modules",
    "db:dev": "docker compose up -d postgres redis",
    "db:dev:stop": "docker compose down",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "20.3.1",
    "@commitlint/config-conventional": "20.3.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "axios": "^1.7.8",
    "husky": "^9.1.0",
    "jest": "^29.7.0",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.0",
    "rimraf": "^6.0.0",
    "ts-jest": "^29.2.5",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "ws": "^8.18.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {}
  }
}
