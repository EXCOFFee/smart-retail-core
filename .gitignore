# ============================================================================
# SMART_RETAIL - Git Ignore
# ============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# Dependencies
# ─────────────────────────────────────────────────────────────────────────────
node_modules/
.pnpm-store/

# ─────────────────────────────────────────────────────────────────────────────
# Build outputs
# ─────────────────────────────────────────────────────────────────────────────
dist/
build/
.next/
.expo/
*.tsbuildinfo

# ─────────────────────────────────────────────────────────────────────────────
# Environment files (CRÍTICO: nunca subir secretos)
# ─────────────────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key
private.pem
public.pem

# ─────────────────────────────────────────────────────────────────────────────
# IDE / Editor
# ─────────────────────────────────────────────────────────────────────────────
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# ─────────────────────────────────────────────────────────────────────────────
# OS
# ─────────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ─────────────────────────────────────────────────────────────────────────────
# Testing
# ─────────────────────────────────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov

# ─────────────────────────────────────────────────────────────────────────────
# Logs
# ─────────────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─────────────────────────────────────────────────────────────────────────────
# Turborepo
# ─────────────────────────────────────────────────────────────────────────────
.turbo/

# ─────────────────────────────────────────────────────────────────────────────
# Docker
# ─────────────────────────────────────────────────────────────────────────────
docker/volumes/

# ─────────────────────────────────────────────────────────────────────────────
# Misc
# ─────────────────────────────────────────────────────────────────────────────
*.tgz
.cache/
tmp/
temp/
.vercel
.env*.local
