# SMART_RETAIL pnpm configuration
# ===============================
# Configuración para resolver conflictos de tipos en monorepo
# con React 18 (mobile) y React 19 (admin-web)

# Habilitar shamefully-hoist para React Native
shamefully-hoist=true

# Guardar el lockfile exacto
save-exact=true

# Aislamiento de tipos de React por workspace
hoist-pattern[]=*
hoist-pattern[]=!@types/react
hoist-pattern[]=!@types/react-dom

# ─────────────────────────────────────────────────────────────────────────────
# BLOQUEAR npm/yarn - Solo pnpm permitido (SRS Rule)
# ─────────────────────────────────────────────────────────────────────────────
engine-strict=true
