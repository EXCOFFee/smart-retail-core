# ============================================================================
# SMART_RETAIL - Variables de Entorno (Backend)
# ============================================================================
# IMPORTANTE: Este archivo es un TEMPLATE. 
# Copia a .env.local para desarrollo y NUNCA lo subas a Git.
# ============================================================================

# ┌─────────────────────────────────────────────────────────────────────────┐
# │ GENERAL                                                                  │
# └─────────────────────────────────────────────────────────────────────────┘
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# ┌─────────────────────────────────────────────────────────────────────────┐
# │ BASE DE DATOS (PostgreSQL 17+)                                          │
# └─────────────────────────────────────────────────────────────────────────┘
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=smartRetail
DB_PASSWORD=smart_retail_secret_2026
DB_DATABASE=smart_retail_db
DB_SYNCHRONIZE=false
DB_LOGGING=true

# ┌─────────────────────────────────────────────────────────────────────────┐
# │ CACHE (Redis 7+)                                                         │
# └─────────────────────────────────────────────────────────────────────────┘
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# TTL del Soft Lock para stock (en segundos)
REDIS_STOCK_LOCK_TTL=30

# ┌─────────────────────────────────────────────────────────────────────────┐
# │ JWT (Autenticación)                                                      │
# └─────────────────────────────────────────────────────────────────────────┘
# IMPORTANTE: Generar claves RS256 para producción con:
# openssl genrsa -out private.pem 2048
# openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY=your-private-key-here
JWT_PUBLIC_KEY=your-public-key-here
JWT_ACCESS_TOKEN_TTL=900
JWT_REFRESH_TOKEN_TTL=604800

# ┌─────────────────────────────────────────────────────────────────────────┐
# │ PASARELAS DE PAGO                                                        │
# └─────────────────────────────────────────────────────────────────────────┘
# Mercado Pago
MP_ACCESS_TOKEN=your-mercadopago-access-token
MP_PUBLIC_KEY=your-mercadopago-public-key
MP_WEBHOOK_SECRET=your-webhook-secret

# MODO (Billeteras Bancarias)
MODO_API_URL=https://api.modo.com.ar
MODO_CLIENT_ID=your-modo-client-id
MODO_CLIENT_SECRET=your-modo-client-secret

# ┌─────────────────────────────────────────────────────────────────────────┐
# │ MONEDA Y LOCALIZACIÓN                                                    │
# └─────────────────────────────────────────────────────────────────────────┘
# Moneda base del sistema (ARS, USD, etc.)
BASE_CURRENCY=ARS

# ┌─────────────────────────────────────────────────────────────────────────┐
# │ TIMEOUTS Y RESILIENCIA                                                   │
# └─────────────────────────────────────────────────────────────────────────┘
# Timeout para llamadas a pasarela de pagos (ms)
PAYMENT_GATEWAY_TIMEOUT=5000

# Timeout para esperar ACK del hardware (ms)
HARDWARE_ACK_TIMEOUT=5000

# ┌─────────────────────────────────────────────────────────────────────────┐
# │ LOGGING                                                                  │
# └─────────────────────────────────────────────────────────────────────────┘
LOG_LEVEL=debug
